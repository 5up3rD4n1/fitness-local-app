  },
  "14": {
    "class_type": "ControlNetLoader",
    "inputs": {"control_net_name": "flux-controlnet-union-pro.safetensors"}
  },
  "20": {
    "class_type": "LoadImage",
    "inputs": {"image": "PLACEHOLDER_OPENPOSE.png"}
  },
  "21": {
    "class_type": "SaveImage",
    "inputs": {"filename_prefix": "lnart", "images": ["9", 0]}
  }
