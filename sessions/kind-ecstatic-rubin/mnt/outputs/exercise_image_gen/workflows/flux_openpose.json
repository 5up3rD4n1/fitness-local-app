{
  "_comment": "Minimal ComfyUI workflow template for Flux.1 dev + ControlNet OpenPose + Style LoRA. Adjust ckpt/lora/controlnet filenames to your local installation. Generate from ComfyUI by enabling 'Dev mode' and using 'Save (API Format)' to obtain a fully-resolved file with correct node IDs.",
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0,
      "steps": 28,
      "cfg": 3.5,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0,
      "model": ["10", 0],
      "positive": ["13", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0]
    }
  },
  "4": {
