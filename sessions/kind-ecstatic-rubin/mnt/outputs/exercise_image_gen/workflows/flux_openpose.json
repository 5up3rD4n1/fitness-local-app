  },
  "13": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["6", 0],
      "negative": ["7", 0],
      "control_net": ["14", 0],
      "image": ["20", 0],
      "strength": 0.75,
      "start_percent": 0.0,
      "end_percent": 0.85
